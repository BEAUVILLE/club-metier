<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title>DIGIYLYFE — Diaporama Club des Métiers du Terrain</title>
<meta name="description" content="DIGIYLYFE — Club des Métiers du Terrain. Chauffeur, logement, réservation, artisans, boutiques, emploi." />

<meta property="og:title" content="DIGIYLYFE — Club des Métiers du Terrain" />
<meta property="og:description" content="DIGIY vous donne les bras numériques. Saly, Mbour, Petite Côte, Sénégal." />
<meta property="og:image" content="https://digiylyfe.net/wp-content/uploads/2026/06/ChatGPT-Image-16-juin-2026-23_15_19.png" />
<meta property="og:type" content="video.other" />

<meta name="theme-color" content="#021f13" />

<style>
  :root{
    --gold:#d8ad3d;
    --gold2:#f3d47a;
    --white:#fff8e8;
    --muted:#d9cfad;
  }

  *{box-sizing:border-box}

  html,body{
    margin:0;
    min-height:100%;
    background:
      radial-gradient(circle at top, rgba(243,212,122,.16), transparent 32rem),
      linear-gradient(180deg, #02180f 0%, #052717 55%, #010b07 100%);
    color:var(--white);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
  }

  body{
    display:flex;
    flex-direction:column;
    align-items:center;
    min-height:100vh;
    padding:22px 16px 32px;
  }

  .brand{
    text-align:center;
    margin-bottom:16px;
  }

  .brand .kicker{
    color:var(--gold2);
    text-transform:uppercase;
    letter-spacing:.16em;
    font-size:.78rem;
    font-weight:800;
    margin:0 0 6px;
  }

  .brand h1{
    margin:0;
    font-size:clamp(1.3rem, 4vw, 1.9rem);
    line-height:1.1;
    letter-spacing:-.02em;
    text-transform:uppercase;
  }

  .brand h1 span{
    color:var(--gold);
  }

  .video-wrap{
    position:relative;
    width:min(100%, 420px);
    border-radius:26px;
    padding:8px;
    background:linear-gradient(145deg, rgba(243,212,122,.85), rgba(216,173,61,.2), rgba(255,255,255,.12));
    box-shadow:0 26px 70px rgba(0,0,0,.5);
  }

  .video-wrap video{
    display:block;
    width:100%;
    height:auto;
    border-radius:20px;
    background:#000;
  }

  .actions{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    justify-content:center;
    margin-top:20px;
    width:min(100%, 420px);
  }

  .btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    flex:1 1 auto;
    min-height:48px;
    padding:12px 18px;
    border-radius:999px;
    text-decoration:none;
    font-weight:900;
    letter-spacing:.01em;
    border:1px solid rgba(243,212,122,.5);
    cursor:pointer;
    font-family:inherit;
  }

  .btn.primary{
    color:#04180e;
    background:linear-gradient(135deg, var(--gold2), var(--gold));
    box-shadow:0 14px 30px rgba(216,173,61,.16);
  }

  .btn.secondary{
    color:var(--white);
    background:rgba(255,255,255,.06);
  }

  .toast{
    position:fixed;
    left:50%;
    bottom:calc(18px + env(safe-area-inset-bottom));
    transform:translate(-50%,18px);
    z-index:40;
    opacity:0;
    pointer-events:none;
    padding:12px 16px;
    border-radius:999px;
    border:1px solid rgba(243,212,122,.42);
    color:#04180e;
    background:linear-gradient(135deg, var(--gold2), var(--gold));
    box-shadow:0 16px 40px rgba(0,0,0,.24);
    font-size:.92rem;
    font-weight:1000;
    transition:opacity .18s ease, transform .18s ease;
  }

  .toast.show{
    opacity:1;
    transform:translate(-50%,0);
  }

  footer{
    margin-top:26px;
    text-align:center;
    color:rgba(255,248,232,.62);
    font-size:.85rem;
  }
</style>
</head>

<body>

  <div class="brand">
    <p class="kicker">Saly • Mbour • Petite Côte • Sénégal</p>
    <h1>Club des <span>métiers</span> du terrain</h1>
  </div>

  <div class="video-wrap">
    <video
      id="diapoVideo"
      src="digiylyfe-diaporama-club-metiers.mp4"
      controls
      autoplay
      muted
      loop
      playsinline
    ></video>
  </div>

  <div class="actions">
    <a class="btn primary" href="https://digiylyfe.com/" target="_blank" rel="noopener">Visiter digiylyfe.com</a>
    <button class="btn secondary" type="button" onclick="shareDiapo()">Partager</button>
  </div>

  <footer>
    DIGIYLYFE — Zéro commission • 100% indépendance • La main dans la main
  </footer>

  <div class="toast" id="toast" role="status" aria-live="polite">Lien copié ✅</div>

  <script>
    (function(){
      "use strict";

      const shareUrl = window.location.href;
      const shareTitle = "DIGIYLYFE — Club des Métiers du Terrain";
      const shareText = "DIGIYLYFE — Club des Métiers du Terrain. Chauffeur, logement, réservation, artisans, boutiques, emploi. " + shareUrl;

      function toast(message){
        const box = document.getElementById("toast");
        if(!box) return;
        box.textContent = message || "Lien copié ✅";
        box.classList.add("show");
        clearTimeout(window.__digiyToast);
        window.__digiyToast = setTimeout(function(){
          box.classList.remove("show");
        }, 1800);
      }

      window.shareDiapo = async function(){
        try{
          if(navigator.share){
            await navigator.share({ title: shareTitle, text: shareText, url: shareUrl });
            return;
          }
          if(navigator.clipboard && window.isSecureContext){
            await navigator.clipboard.writeText(shareUrl);
            toast("Lien copié ✅");
          }else{
            toast("Copie manuelle : " + shareUrl);
          }
        }catch(e){
          if(e && e.name === "AbortError") return;
        }
      };
    })();
  </script>

</body>
</html>

